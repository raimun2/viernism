{
  "manifest_version": 3,
  "name": "Viernism",
  "version": "1.1",
  "permissions": ["storage"],
  "content_scripts": [
    {
      "matches": ["https://calendar.google.com/calendar/*"],
      "js": ["content.js"]
    },
    {
      "matches": ["https://www.strava.com/athletes/*/training/log*"],
      "js": ["strava.js"]
    }
  ]
}